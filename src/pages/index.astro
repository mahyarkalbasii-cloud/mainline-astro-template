---
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const pageTitle = 'PersianSaze | Targeted sales to active construction projects';
const pageDescription =
  'PersianSaze helps construction suppliers reach the right project at the right time with clearer market execution.';

const constructionStages = [
  'Demolition and excavation',
  'Foundation',
  'Structural framing',
  'Masonry',
  'Plaster base layer',
  'Early finishing',
  'Finishing',
  'Detail finishing',
  'Project completion',
];

const pricingPlans = [
  {
    name: 'Bonyan',
    audience: 'Best for small and mid-sized businesses',
    coverage: 'Plots up to 300 m², includes 3 construction stages',
    price3Month: '7,500,000 toman',
    price6Month: '10,200,000 toman',
    price12Month: '13,500,000 toman',
    extraStagePrice: '2,500,000 toman',
  },
  {
    name: 'Royan',
    audience: 'Best for small and mid-sized businesses',
    coverage: 'Plots up to 500 m², includes 3 construction stages',
    price3Month: '9,900,000 toman',
    price6Month: '13,500,000 toman',
    price12Month: '18,000,000 toman',
    extraStagePrice: '3,300,000 toman',
  },
  {
    name: 'Taban',
    audience: 'Best for mid-sized and larger businesses',
    coverage: 'Plots up to 700 m², includes 3 construction stages',
    price3Month: '12,300,000 toman',
    price6Month: '15,500,000 toman',
    price12Month: '21,000,000 toman',
    extraStagePrice: '4,100,000 toman',
  },
  {
    name: 'Taban Plus',
    audience: 'Best for mid-sized and larger businesses',
    coverage: 'No area limit, includes 3 construction stages',
    price3Month: '15,000,000 toman',
    price6Month: '18,000,000 toman',
    price12Month: '24,000,000 toman',
    extraStagePrice: '5,000,000 toman',
  },
];

const faqItems = [
  {
    question: 'What project information does PersianSaze provide exactly?',
    answer:
      'Project address and location, current construction stage, real photos, contact details of the related person, and general building specs such as area, floor count, and unit count.',
  },
  {
    question: 'How is project information collected?',
    answer:
      'Data is collected through field visits. Projects are identified, recorded, and photographed, then reviewed again on a recurring cycle for updates.',
  },
  {
    question: 'How often is the information updated?',
    answer:
      'Projects are reviewed and updated on a recurring cycle. Construction status, photos, and contact details are checked each cycle and corrected when changes are found.',
  },
  {
    question: 'Which areas does PersianSaze cover?',
    answer: 'Current primary coverage is Tehran, Karaj, and Lavasan.',
  },
  {
    question: 'Is PersianSaze only a project list or contact database?',
    answer:
      'No. PersianSaze is not just project display or phone numbers. Alongside live project data, it includes execution tools such as CRM and smart SMS, plus training on how to use them effectively.',
  },
  {
    question: 'Can I see a demo before purchasing?',
    answer:
      'Yes. When you request a demo, a PersianSaze specialist shows you the platform environment, usage flow, and key capabilities.',
  },
  {
    question: 'What is the difference between subscription plans?',
    answer: 'Plans are defined by subscription type, selected construction stages, and subscription duration.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<DefaultLayout title={pageTitle} description={pageDescription} lang="en" dir="ltr" showNavbar={false} showFooter={false}>
  <div class="bg-[#FAFAF7] text-[#1F1E1D]">
    <header class="sticky top-0 z-30 border-b border-[#E8E4DD] bg-[#FAFAF7]/95 backdrop-blur-sm">
      <div class="container flex items-center justify-between py-4">
        <a href="/" class="text-base font-bold">PersianSaze</a>
        <a
          href="/contact"
          class="rounded-full bg-[#1F1E1D] px-4 py-2 text-sm font-medium text-[#F0EBE2]"
        >
          Request Demo
        </a>
      </div>
    </header>

    <main>
      <section id="hero" class="container py-14 text-center sm:py-20">
        <p class="mx-auto inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">
          Primary coverage: Tehran, Karaj, and Lavasan
        </p>
        <h1 class="mx-auto mt-6 max-w-4xl text-4xl leading-[1.25] font-bold sm:text-5xl sm:leading-[1.2]">
          Active construction projects<br />
          across Tehran, Karaj, and Lavasan
        </h1>
        <p class="mx-auto mt-8 max-w-2xl text-base leading-8 sm:text-lg sm:leading-9">
          In the construction products and services market, successful sales begin with reaching the
          right project at the right time.
          <br />
          PersianSaze helps shorten that path.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="rounded-full bg-[#D97757] px-5 py-2.5 text-sm font-medium text-white">
            Request Demo
          </a>
          <a
            href="#solution"
            class="rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-5 py-2.5 text-sm font-medium"
          >
            Platform Capabilities
          </a>
        </div>
      </section>

      <section id="problem" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="max-w-3xl text-3xl leading-tight font-bold sm:text-4xl">
          In construction sales,<br />
          having a good product is not enough
        </h2>
        <p class="mt-6 max-w-3xl text-base leading-8 sm:text-lg sm:leading-9">
          Projects are scattered, market data is not always accurate and current,
          <br />
          and when contact happens too early or too late, sales opportunities disappear.
          <br />
          That is why finding the right project is still time-consuming,
          <br />
          costly, and draining for many suppliers.
        </p>
      </section>

      <section id="solution" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="max-w-4xl text-3xl leading-tight font-bold sm:text-4xl">
          PersianSaze makes it easier to find the right projects
        </h2>
        <p class="mt-6 max-w-4xl text-base leading-8 sm:text-lg sm:leading-9">
          With live data from active construction projects, execution tools such as CRM and smart SMS,
          and practical training for proper usage, PersianSaze helps you spot relevant opportunities
          sooner and move your sales process forward with more focus.
        </p>

        <div class="mt-8 grid gap-4 lg:grid-cols-3">
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-6">
            <h3 class="text-xl font-bold">Up-to-date project information</h3>
            <p class="mt-4 text-sm leading-7">
              Project address, construction stage, real photos, and contact details are collected and
              refreshed through a clear process so your team can identify better-fit projects faster.
            </p>
            <a
              href="#"
              class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#FAFAF7] px-3 py-1.5 text-xs font-medium"
            >
              View Details
            </a>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-xl font-bold">Sales execution tools</h3>
            <p class="mt-4 text-sm leading-7">
              With tools such as map search, filters, CRM, and smart SMS, finding, tracking, and
              advancing sales opportunities becomes more structured and easier to run.
            </p>
            <a
              href="#"
              class="mt-5 inline-flex rounded-full bg-[#1F1E1D] px-3 py-1.5 text-xs font-medium text-[#F0EBE2]"
            >
              View Details
            </a>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-6">
            <h3 class="text-xl font-bold">Training for better usage</h3>
            <p class="mt-4 text-sm leading-7">
              Your team gets more than access to data. They learn how to search better, follow up more
              effectively, and move with clearer intent.
            </p>
            <a
              href="#"
              class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#FAFAF7] px-3 py-1.5 text-xs font-medium"
            >
              View Details
            </a>
          </article>
        </div>
      </section>

      <section id="how-it-works" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">How it works</p>
        <p class="mt-5 max-w-4xl text-base leading-8 sm:text-lg sm:leading-9">
          PersianSaze is not just project display. From data collection and refreshing to opportunity
          identification, outreach, and follow-up, it builds a clear operating path for sales.
        </p>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg font-bold">Data collection and update layer</h3>
            <p class="mt-3 text-sm leading-7">
              Active construction project data is gathered through field operations and continuously
              refreshed so your team can work with a more live and trustworthy market view.
            </p>
            <a
              href="#"
              class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-3 py-1.5 text-xs font-medium"
            >
              Learn More
            </a>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg font-bold">AI layer</h3>
            <p class="mt-3 text-sm leading-7">
              PersianSaze AI helps you evaluate projects with more confidence, spot better-fit
              opportunities faster, and make clearer decisions about when to act.
            </p>
            <a
              href="#"
              class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-3 py-1.5 text-xs font-medium"
            >
              Learn More
            </a>
          </article>
        </div>
      </section>

      <section id="usage-steps" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl font-bold sm:text-4xl">Usage steps</h2>
        <ol class="mt-8 grid gap-4 md:grid-cols-2">
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">Step 1</p>
            <h3 class="mt-3 text-lg font-bold">Find the right project</h3>
            <p class="mt-3 text-sm leading-7">
              With filters, map view, and updated project data, you can find opportunities aligned with
              your sales focus more quickly.
            </p>
          </li>
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">Step 2</p>
            <h3 class="mt-3 text-lg font-bold">Review each project</h3>
            <p class="mt-3 text-sm leading-7">
              By checking construction stage, real photos, and project details, your team can judge
              which opportunities are more ready for contact and discussion.
            </p>
          </li>
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">Step 3</p>
            <h3 class="mt-3 text-lg font-bold">Start outreach</h3>
            <p class="mt-3 text-sm leading-7">
              Once a suitable project is selected, you can initiate outreach at the right time using
              available contact information and communication tools.
            </p>
          </li>
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">Step 4</p>
            <h3 class="mt-3 text-lg font-bold">Move follow-up forward</h3>
            <p class="mt-3 text-sm leading-7">
              With CRM and execution tools, follow-ups stay recorded and your pipeline moves from
              scattered activity to a more consistent rhythm.
            </p>
          </li>
        </ol>
        <div class="mt-6 rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-6">
          <p class="inline-flex rounded-full bg-[#1F1E1D] px-3 py-1 text-xs font-medium text-[#F0EBE2]">Outcome</p>
          <p class="mt-3 text-lg font-bold">More focused, more effective sales</p>
        </div>
      </section>

      <section id="construction-stages" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl font-bold sm:text-4xl">Construction stages covered</h2>
        <ul class="mt-6 flex flex-wrap gap-2.5">
          {
            constructionStages.map((stage) => (
              <li class="rounded-full border border-[#E8E4DD] bg-[#FAFAF7] px-3 py-1.5 text-xs">{stage}</li>
            ))
          }
        </ul>
      </section>

      <section id="who-uses" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl font-bold sm:text-4xl">Who uses PersianSaze</h2>
        <p class="mt-6 max-w-3xl text-base leading-8 sm:text-lg sm:leading-9">
          If your product or service is sold into active construction projects,
          <br />
          PersianSaze can be a practical fit for your sales team.
        </p>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg leading-8 font-bold">When speed to project matters most</h3>
            <p class="mt-3 text-sm leading-7">
              For products and services with a short gap between need, purchase, and execution,
              <br />
              the core advantage is reaching ready-to-buy projects sooner.
            </p>
            <div class="my-4 h-px w-full bg-[#E8E4DD]"></div>
            <p class="text-sm font-medium">Examples:</p>
            <p class="mt-2 text-sm leading-7">Cement, brick, plaster, rebar, sand and gravel, base materials</p>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg leading-8 font-bold">When entering negotiation earlier matters more</h3>
            <p class="mt-3 text-sm leading-7">
              For products and services with longer purchase decisions,
              <br />
              the core advantage is entering the project's decision window earlier.
            </p>
            <div class="my-4 h-px w-full bg-[#E8E4DD]"></div>
            <p class="text-sm font-medium">Examples:</p>
            <p class="mt-2 text-sm leading-7">Elevators, MEP systems, façade, doors and windows, cabinets, engineering services</p>
          </article>
        </div>
      </section>

      <section id="pricing" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl font-bold sm:text-4xl">Plans and pricing</h2>
        <p class="mt-5 max-w-3xl text-base leading-8">
          Plans are defined by subscription type, selected construction stages, and subscription duration.
        </p>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          {pricingPlans.map((plan) => (
            <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
              <h3 class="text-xl font-bold">{plan.name}</h3>
              <ul class="mt-4 space-y-2.5 text-sm leading-7">
                <li>{plan.audience}</li>
                <li>{plan.coverage}</li>
                <li><span class="font-bold">3 months:</span> {plan.price3Month}</li>
                <li><span class="font-bold">6 months:</span> {plan.price6Month}</li>
                <li><span class="font-bold">12 months:</span> {plan.price12Month}</li>
                <li><span class="font-bold">Each extra stage:</span> {plan.extraStagePrice}</li>
              </ul>
            </article>
          ))}
        </div>

        <p class="mt-6 rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-5 text-sm leading-7">
          All subscriptions include: real-time access, CRM, SMS panel, and training workshops.
        </p>
        <a href="/contact" class="mt-6 inline-flex rounded-full bg-[#1F1E1D] px-5 py-2.5 text-sm font-medium text-[#F0EBE2]">
          Get Plan Guidance
        </a>
      </section>

      <section id="faq" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl font-bold sm:text-4xl">Frequently asked questions</h2>
        <p class="mt-4 text-base leading-8">Short answers to the questions we hear most often.</p>

        <div class="mt-8 space-y-3">
          {faqItems.map((item, index) => (
            <details class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-5" open={index === 0}>
              <summary class="cursor-pointer text-sm leading-7 font-bold">{item.question}</summary>
              <p class="mt-3 text-sm leading-7">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="final-cta" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="max-w-4xl text-3xl leading-tight font-bold sm:text-4xl">
          If you want to reach better-fit projects sooner,
          <br />
          request a PersianSaze demo
        </h2>
        <p class="mt-6 max-w-3xl text-base leading-8 sm:text-lg sm:leading-9">
          In a short demo, you can review the platform environment, key capabilities, and sample
          projects relevant to your sales domain.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-full bg-[#D97757] px-5 py-2.5 text-sm font-medium text-white">
            Request Demo
          </a>
          <a href="#solution" class="rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-5 py-2.5 text-sm font-medium">
            Platform Capabilities
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t border-[#E8E4DD] py-10">
      <div class="container">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-lg font-bold">PersianSaze</p>
            <p class="mt-2 text-sm leading-7">A structured sales system for active construction projects</p>
          </div>
          <nav>
            <ul class="flex flex-wrap justify-start gap-x-5 gap-y-2 text-sm sm:justify-end">
              <li><a href="#how-it-works">How It Works</a></li>
              <li><a href="#pricing">Plans</a></li>
              <li><a href="#faq">FAQ</a></li>
              <li><a href="/contact">Contact / Request Demo</a></li>
            </ul>
          </nav>
        </div>
        <p class="mt-8 border-t border-[#E8E4DD] pt-5 text-xs">© {new Date().getFullYear()} PersianSaze. All rights reserved.</p>
      </div>
    </footer>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</DefaultLayout>
