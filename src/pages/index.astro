---
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const pageTitle = 'پرشین‌سازه | فروش هدفمند به پروژه‌های ساختمانی در حال ساخت';
const pageDescription =
  'پرشین‌سازه به تأمین‌کنندگان کمک می‌کند با داده‌های زنده پروژه و ابزارهای اجرایی، در زمان درست به پروژه مناسب برسند.';

const constructionStages = [
  'تخریب و گودبرداری',
  'فونداسیون',
  'اسکلت‌بندی',
  'دیوارچینی',
  'گچ و خاک',
  'ابتدای نازک‌کاری',
  'نازک‌کاری',
  'ظریف‌کاری',
  'پایان کار',
];

const pricingPlans = [
  {
    name: 'بنیان',
    audience: 'مناسب کسب‌وکارهای کوچک و متوسط',
    coverage: 'پلاک‌های تا ۳۰۰ مترمربع، شامل ۳ مرحله ساخت',
    price3Month: '۷,۵۰۰,۰۰۰ تومان',
    price6Month: '۱۰,۲۰۰,۰۰۰ تومان',
    price12Month: '۱۳,۵۰۰,۰۰۰ تومان',
    extraStagePrice: '۲,۵۰۰,۰۰۰ تومان',
  },
  {
    name: 'رویان',
    audience: 'مناسب کسب‌وکارهای کوچک و متوسط',
    coverage: 'پلاک‌های تا ۵۰۰ مترمربع، شامل ۳ مرحله ساخت',
    price3Month: '۹,۹۰۰,۰۰۰ تومان',
    price6Month: '۱۳,۵۰۰,۰۰۰ تومان',
    price12Month: '۱۸,۰۰۰,۰۰۰ تومان',
    extraStagePrice: '۳,۳۰۰,۰۰۰ تومان',
  },
  {
    name: 'تابان',
    audience: 'مناسب کسب‌وکارهای متوسط و بزرگ‌تر',
    coverage: 'پلاک‌های تا ۷۰۰ مترمربع، شامل ۳ مرحله ساخت',
    price3Month: '۱۲,۳۰۰,۰۰۰ تومان',
    price6Month: '۱۵,۵۰۰,۰۰۰ تومان',
    price12Month: '۲۱,۰۰۰,۰۰۰ تومان',
    extraStagePrice: '۴,۱۰۰,۰۰۰ تومان',
  },
  {
    name: 'تابان پلاس',
    audience: 'مناسب کسب‌وکارهای متوسط و بزرگ‌تر',
    coverage: 'بدون محدودیت متراژ، شامل ۳ مرحله ساخت',
    price3Month: '۱۵,۰۰۰,۰۰۰ تومان',
    price6Month: '۱۸,۰۰۰,۰۰۰ تومان',
    price12Month: '۲۴,۰۰۰,۰۰۰ تومان',
    extraStagePrice: '۵,۰۰۰,۰۰۰ تومان',
  },
];

const faqItems = [
  {
    question: 'پرشین‌سازه دقیقاً چه اطلاعاتی از پروژه‌ها ارائه می‌دهد؟',
    answer:
      'آدرس و موقعیت پروژه، مرحله ساخت، تصاویر واقعی، اطلاعات تماس فرد مرتبط با پروژه، و مشخصات عمومی سازه مثل متراژ، تعداد طبقات و تعداد واحدها.',
  },
  {
    question: 'اطلاعات پروژه‌ها از کجا جمع‌آوری می‌شود؟',
    answer:
      'اطلاعات از طریق بازدید میدانی و حضوری جمع‌آوری می‌شود. پروژه‌ها شناسایی، ثبت و تصویربرداری می‌شوند و بعد به‌صورت دوره‌ای دوباره بررسی و به‌روزرسانی می‌شوند.',
  },
  {
    question: 'هر چند وقت اطلاعات به‌روزرسانی می‌شود؟',
    answer:
      'پروژه‌ها به‌صورت دوره‌ای بازبینی و به‌روزرسانی می‌شوند. وضعیت ساخت، تصاویر و اطلاعات تماس در هر دوره بررسی می‌شود و در صورت تغییر، اصلاح می‌گردد.',
  },
  {
    question: 'پرشین‌سازه چه مناطقی را پوشش می‌دهد؟',
    answer: 'در حال حاضر پوشش اصلی پرشین‌سازه تهران، کرج و لواسان است.',
  },
  {
    question: 'پرشین‌سازه فقط یک لیست پروژه یا بانک شماره است؟',
    answer:
      'خیر. پرشین‌سازه فقط نمایش پروژه یا شماره تماس نیست. این سامانه در کنار داده‌های زنده پروژه، ابزارهای اجرایی مثل CRM و پیامک هوشمند و آموزش استفاده از آن‌ها را هم در اختیار شما می‌گذارد.',
  },
  {
    question: 'آیا می‌توانم قبل از خرید دمو ببینم؟',
    answer:
      'بله. با درخواست دمو، کارشناس پرشین‌سازه محیط سامانه، نحوه استفاده و امکانات آن را به شما نشان می‌دهد.',
  },
  {
    question: 'فرق طرح‌های اشتراکی چیست؟',
    answer: 'طرح‌ها بر اساس نوع اشتراک، تعداد مراحل ساخت انتخابی و مدت اشتراک تعریف می‌شوند.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<DefaultLayout title={pageTitle} description={pageDescription} lang="fa" dir="rtl" showNavbar={false} showFooter={false}>
  <div class="bg-[#FAFAF7] text-[#1F1E1D]">
    <header class="sticky top-0 z-30 border-b border-[#E8E4DD] bg-[#FAFAF7]/95 backdrop-blur-sm">
      <div class="container flex items-center justify-between py-4">
        <a href="/" class="text-base font-bold">پرشین‌سازه</a>
        <a href="/contact" class="rounded-full bg-[#1F1E1D] px-4 py-2 text-sm font-medium text-[#F0EBE2]">
          مشاهده دمو
        </a>
      </div>
    </header>

    <main>
      <section id="hero" class="container py-14 text-center sm:py-20">
        <p class="mx-auto inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">پوشش اصلی: تهران، کرج و لواسان</p>
        <h1 class="mx-auto mt-6 max-w-4xl text-4xl leading-[1.55] font-bold sm:text-5xl sm:leading-[1.5]">
          پروژه‌های ساختمانی در حال ساخت<br />
          در تهران، کرج و لواسان
        </h1>
        <p class="mx-auto mt-8 max-w-2xl text-base leading-[2.15] sm:text-lg sm:leading-[2.2]">
          در بازار محصولات و خدمات ساختمانی، فروش موفق از رسیدن به پروژه درست در زمان درست شروع می‌شود.<br />
          پرشین‌سازه این مسیر را کوتاه‌تر می‌کند.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="rounded-full bg-[#D97757] px-5 py-2.5 text-sm font-medium text-white">مشاهده دمو</a>
          <a href="#solution" class="rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-5 py-2.5 text-sm font-medium">
            امکانات سامانه
          </a>
        </div>
      </section>

      <section id="problem" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="max-w-3xl text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">
          فروش در بازار ساختمان،<br />
          فقط به داشتن محصول خوب بستگی ندارد
        </h2>
        <p class="mt-6 max-w-3xl text-base leading-[2.15] sm:text-lg sm:leading-[2.2]">
          پروژه‌ها پراکنده‌اند، اطلاعات بازار همیشه دقیق و به‌روز نیست،<br />
          و اگر تماس زود یا دیر انجام شود، فرصت فروش از بین می‌رود.<br />
          برای همین پیدا کردن پروژه مناسب، هنوز برای خیلی از تأمین‌کنندگان<br />
          یک کار زمان‌بر، پرهزینه و فرسایشی است.
        </p>
      </section>

      <section id="solution" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="max-w-4xl text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">پرشین‌سازه پیدا کردن پروژه مناسب را ساده‌تر می‌کند</h2>
        <p class="mt-6 max-w-4xl text-base leading-[2.15] sm:text-lg sm:leading-[2.2]">
          پرشین‌سازه با داده‌های زنده پروژه‌های در حال ساخت، ابزارهای اجرایی مثل CRM و پیامک هوشمند، و آموزش استفاده درست از این ابزارها، به شما کمک می‌کند فرصت‌های مناسب را زودتر ببینید و مسیر فروش را هدفمندتر پیش ببرید.
        </p>

        <div class="mt-8 grid gap-4 lg:grid-cols-3">
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-6">
            <h3 class="text-xl leading-[1.8] font-bold">اطلاعات به‌روز پروژه‌ها</h3>
            <p class="mt-4 text-sm leading-[2.1]">
              آدرس پروژه، مرحله ساخت، تصاویر واقعی و اطلاعات تماس، در یک مسیر مشخص جمع‌آوری و به‌روزرسانی می‌شود تا بتوانید دقیق‌تر پروژه مناسب را پیدا کنید.
            </p>
            <a href="#" class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#FAFAF7] px-3 py-1.5 text-xs font-medium">مشاهده جزئیات</a>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-xl leading-[1.8] font-bold">ابزارهای اجرایی فروش</h3>
            <p class="mt-4 text-sm leading-[2.1]">
              با ابزارهایی مثل نقشه، فیلترها، CRM و پیامک هوشمند، پیدا کردن، پیگیری و جلو بردن فرصت‌های فروش ساده‌تر و منظم‌تر می‌شود.
            </p>
            <a href="#" class="mt-5 inline-flex rounded-full bg-[#1F1E1D] px-3 py-1.5 text-xs font-medium text-[#F0EBE2]">مشاهده جزئیات</a>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-6">
            <h3 class="text-xl leading-[1.8] font-bold">آموزش برای استفاده بهتر</h3>
            <p class="mt-4 text-sm leading-[2.1]">
              تیم شما فقط به اطلاعات دسترسی ندارد؛ یاد می‌گیرد چگونه بهتر جست‌وجو کند، درست‌تر پیگیری کند و هدفمندتر جلو برود.
            </p>
            <a href="#" class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#FAFAF7] px-3 py-1.5 text-xs font-medium">مشاهده جزئیات</a>
          </article>
        </div>
      </section>

      <section id="how-it-works" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">چطور کار می‌کند</p>
        <p class="mt-5 max-w-4xl text-base leading-[2.15] sm:text-lg sm:leading-[2.2]">
          پرشین‌سازه فقط نمایش پروژه نیست؛ از جمع‌آوری و به‌روزرسانی اطلاعات تا شناسایی فرصت، ارتباط و پیگیری، یک مسیر روشن برای فروش می‌سازد.
        </p>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg leading-[1.9] font-bold">لایه جمع‌آوری و به‌روزرسانی اطلاعات</h3>
            <p class="mt-3 text-sm leading-[2.1]">
              اطلاعات پروژه‌های در حال ساخت به‌صورت میدانی جمع‌آوری می‌شود و به‌طور مستمر به‌روزرسانی می‌ماند تا شما به یک تصویر زنده‌تر و قابل‌اعتمادتر از بازار دسترسی داشته باشید.
            </p>
            <a href="#" class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-3 py-1.5 text-xs font-medium">بیشتر بدانید</a>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg leading-[1.9] font-bold">لایه هوش مصنوعی</h3>
            <p class="mt-3 text-sm leading-[2.1]">
              هوش مصنوعی پرشین‌سازه به شما کمک می‌کند پروژه‌ها را بهتر ارزیابی کنید، فرصت‌های مناسب‌تر را سریع‌تر ببینید و تصمیم دقیق‌تری برای اقدام بگیرید.
            </p>
            <a href="#" class="mt-5 inline-flex rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-3 py-1.5 text-xs font-medium">بیشتر بدانید</a>
          </article>
        </div>
      </section>

      <section id="usage-steps" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">مسیر استفاده</h2>
        <ol class="mt-8 grid gap-4 md:grid-cols-2">
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">گام ۱</p>
            <h3 class="mt-3 text-lg leading-[1.9] font-bold">پروژه مناسب را پیدا کنید</h3>
            <p class="mt-3 text-sm leading-[2.1]">با فیلترها، نقشه و اطلاعات به‌روز پروژه‌ها، می‌توانید فرصت‌های مرتبط با حوزه کاری خود را سریع‌تر پیدا کنید.</p>
          </li>
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">گام ۲</p>
            <h3 class="mt-3 text-lg leading-[1.9] font-bold">پروژه را بررسی کنید</h3>
            <p class="mt-3 text-sm leading-[2.1]">با دیدن مرحله ساخت، تصاویر واقعی و اطلاعات پروژه، راحت‌تر تشخیص می‌دهید کدام فرصت برای تماس و مذاکره مناسب‌تر است.</p>
          </li>
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">گام ۳</p>
            <h3 class="mt-3 text-lg leading-[1.9] font-bold">ارتباط را شروع کنید</h3>
            <p class="mt-3 text-sm leading-[2.1]">بعد از انتخاب پروژه مناسب، می‌توانید با اطلاعات تماس موجود و ابزارهای ارتباطی، ارتباط را در زمان مناسب شروع کنید.</p>
          </li>
          <li class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <p class="inline-flex rounded-full bg-[#E8E4DD] px-3 py-1 text-xs font-medium">گام ۴</p>
            <h3 class="mt-3 text-lg leading-[1.9] font-bold">پیگیری را جلو ببرید</h3>
            <p class="mt-3 text-sm leading-[2.1]">با CRM و ابزارهای اجرایی، پیگیری‌ها ثبت می‌شود و مسیر فروش از حالت پراکنده به یک روند منظم‌تر تبدیل می‌شود.</p>
          </li>
        </ol>
        <div class="mt-6 rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-6">
          <p class="inline-flex rounded-full bg-[#1F1E1D] px-3 py-1 text-xs font-medium text-[#F0EBE2]">نتیجه</p>
          <p class="mt-3 text-lg leading-[1.9] font-bold">فروش بیشتر و هدفمندتر</p>
        </div>
      </section>

      <section id="construction-stages" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">مراحل ساخت تحت پوشش</h2>
        <ul class="mt-6 flex flex-wrap gap-2.5">
          {
            constructionStages.map((stage) => (
              <li class="rounded-full border border-[#E8E4DD] bg-[#FAFAF7] px-3 py-1.5 text-xs">{stage}</li>
            ))
          }
        </ul>
      </section>

      <section id="who-uses" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">چه کسانی از پرشین‌سازه استفاده می‌کنند</h2>
        <p class="mt-6 max-w-3xl text-base leading-[2.15] sm:text-lg sm:leading-[2.2]">
          اگر محصول یا خدمتی دارید که به پروژه‌های ساختمانی در حال ساخت فروخته می‌شود،<br />
          پرشین‌سازه می‌تواند برای شما کاربردی باشد.
        </p>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg leading-[1.95] font-bold">وقتی سرعت رسیدن مهم‌تر است</h3>
            <p class="mt-3 text-sm leading-[2.1]">
              برای کالاها و خدماتی که فاصله بین نیاز، خرید و اجرا در آن‌ها کوتاه است،<br />
              مهم‌ترین مزیت این است که زودتر به پروژه آماده خرید برسید.
            </p>
            <div class="my-4 h-px w-full bg-[#E8E4DD]"></div>
            <p class="text-sm font-medium">محصولاتی مثل:</p>
            <p class="mt-2 text-sm leading-[2.1]">سیمان، آجر، گچ، میلگرد، شن و ماسه، مصالح پایه</p>
          </article>
          <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
            <h3 class="text-lg leading-[1.95] font-bold">وقتی زودتر وارد مذاکره شدن مهم‌تر است</h3>
            <p class="mt-3 text-sm leading-[2.1]">
              برای کالاها و خدماتی که تصمیم خریدشان زمان می‌برد،<br />
              مهم‌ترین مزیت این است که زودتر وارد فضای تصمیم‌سازی پروژه شوید.
            </p>
            <div class="my-4 h-px w-full bg-[#E8E4DD]"></div>
            <p class="text-sm font-medium">محصولاتی مثل:</p>
            <p class="mt-2 text-sm leading-[2.1]">آسانسور، تأسیسات، نما، درب و پنجره، کابینت، خدمات مهندسی</p>
          </article>
        </div>
      </section>

      <section id="pricing" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">طرح‌ها و تعرفه‌ها</h2>
        <p class="mt-5 max-w-3xl text-base leading-[2.15]">طرح‌ها بر اساس نوع اشتراک، تعداد مراحل ساخت انتخابی و مدت اشتراک تعریف می‌شوند.</p>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          {pricingPlans.map((plan) => (
            <article class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-6">
              <h3 class="text-xl leading-[1.9] font-bold">{plan.name}</h3>
              <ul class="mt-4 space-y-2.5 text-sm leading-[2.1]">
                <li>{plan.audience}</li>
                <li>{plan.coverage}</li>
                <li><span class="font-bold">۳ ماهه:</span> {plan.price3Month}</li>
                <li><span class="font-bold">۶ ماهه:</span> {plan.price6Month}</li>
                <li><span class="font-bold">۱۲ ماهه:</span> {plan.price12Month}</li>
                <li><span class="font-bold">هر مرحله اضافه:</span> {plan.extraStagePrice}</li>
              </ul>
            </article>
          ))}
        </div>

        <p class="mt-6 rounded-2xl border border-[#E8E4DD] bg-[#F0EBE2] p-5 text-sm leading-[2.1]">
          تمامی اشتراک‌ها شامل: دسترسی در لحظه، CRM، پنل پیامک و کارگاه‌های آموزشی
        </p>
        <a href="/contact" class="mt-6 inline-flex rounded-full bg-[#1F1E1D] px-5 py-2.5 text-sm font-medium text-[#F0EBE2]">مشاوره انتخاب پلن</a>
      </section>

      <section id="faq" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">سؤالات پرتکرار</h2>
        <p class="mt-4 text-base leading-[2.15]">پاسخ کوتاه به سؤال‌هایی که بیشتر از ما می‌پرسند.</p>

        <div class="mt-8 space-y-3">
          {faqItems.map((item, index) => (
            <details class="rounded-2xl border border-[#E8E4DD] bg-[#FAFAF7] p-5" open={index === 0}>
              <summary class="cursor-pointer text-sm leading-[2.1] font-bold">{item.question}</summary>
              <p class="mt-3 text-sm leading-[2.1]">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="final-cta" class="container border-t border-[#E8E4DD] py-12 sm:py-16">
        <h2 class="max-w-4xl text-3xl leading-[1.6] font-bold sm:text-4xl sm:leading-[1.55]">
          اگر می‌خواهید زودتر به پروژه‌های مناسب برسید،<br />
          دموی پرشین‌سازه را ببینید
        </h2>
        <p class="mt-6 max-w-3xl text-base leading-[2.15] sm:text-lg sm:leading-[2.2]">
          در یک دموی کوتاه، می‌توانید محیط سامانه، امکانات آن و نمونه پروژه‌های مرتبط با حوزه کاری خود را ببینید.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-full bg-[#D97757] px-5 py-2.5 text-sm font-medium text-white">مشاهده دمو</a>
          <a href="#solution" class="rounded-full border border-[#E8E4DD] bg-[#F0EBE2] px-5 py-2.5 text-sm font-medium">امکانات سامانه</a>
        </div>
      </section>
    </main>

    <footer class="border-t border-[#E8E4DD] py-10">
      <div class="container">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-lg font-bold">پرشین‌سازه</p>
            <p class="mt-2 text-sm leading-[2.1]">یک سیستم ساختاریافته برای فروش بهتر به پروژه‌های ساختمانی در حال ساخت</p>
          </div>
          <nav>
            <ul class="flex flex-wrap justify-start gap-x-5 gap-y-2 text-sm sm:justify-end">
              <li><a href="#how-it-works">چطور کار می‌کند</a></li>
              <li><a href="#pricing">طرح‌ها</a></li>
              <li><a href="#faq">سؤالات پرتکرار</a></li>
              <li><a href="/contact">تماس / مشاهده دمو</a></li>
            </ul>
          </nav>
        </div>
        <p class="mt-8 border-t border-[#E8E4DD] pt-5 text-xs">© {new Date().getFullYear()} پرشین‌سازه. تمامی حقوق محفوظ است.</p>
      </div>
    </footer>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</DefaultLayout>
